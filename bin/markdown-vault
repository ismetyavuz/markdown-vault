#!/usr/bin/env python3
"""Markdown Vault — CLI launcher for desktop file and manual execution."""

import sys
from pathlib import Path

try:
    import setproctitle
    setproctitle.setproctitle("markdown-vault")
except ImportError:
    try:
        with open("/proc/self/comm", "w") as f:
            f.write("markdown-vault\n")
    except OSError:
        pass

project_root = Path(__file__).resolve().parent.parent
if str(project_root) not in sys.path:
    sys.path.insert(0, str(project_root))

from src.main import main

raise SystemExit(main())
