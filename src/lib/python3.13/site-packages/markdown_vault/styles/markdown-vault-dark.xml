<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="markdown-vault-dark" name="Markdown Vault Dark" version="1.0"
              parent-scheme="Adwaita-dark">

  <author>Markdown Vault</author>
  <description>Adwaita Dark with a high-contrast colour for inline code spans</description>

  <!-- Stock Adwaita-dark paints `code spans` in violet_2 (#7D8AC7), which is
       hard to tell apart from body text and links on a dark background.
       orange_1 from the GNOME palette reads clearly and collides with nothing
       else in the Markdown highlighter. -->
  <style name="def:inline-code" foreground="#FFBE6F"/>

</style-scheme>
